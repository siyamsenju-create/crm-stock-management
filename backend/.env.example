# ─────────────────────────────────────────────────────────────────────────────
# CRM Stock Management API — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5005

# ── Database ──────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/crm-stock
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/<db>?appName=<App>
MONGO_URI=mongodb://localhost:27017/crm-stock

# Test DB (used by Jest — separate from dev/prod data)
MONGO_URI_TEST=mongodb://localhost:27017/crm-test

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate secure secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_BYTE_HEX_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (optional — falls back to in-memory if not set) ────────────────────
# Local:  redis://localhost:6379
# Upstash: rediss://<user>:<password>@<host>.upstash.io:6379
# Leave blank to use in-memory caching
REDIS_URL=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
# winston log level: error | warn | info | http | debug
LOG_LEVEL=info
