# ─────────────────────────────────────────────────────────────────────────────
# CRM Stock Management API — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5005

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate secure secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_BYTE_HEX_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (optional — falls back to in-memory if not set) ────────────────────
# Local:  redis://localhost:6379
# Upstash: rediss://<user>:<password>@<host>.upstash.io:6379
# Leave blank to use in-memory caching
REDIS_URL=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ── Logging ───────────────────────────────────────────────────────────────────
# winston log level: error | warn | info | http | debug
LOG_LEVEL=info

# ── Firebase ──────────────────────────────────────────────────────────────────
# Used by the backend to connect to and query Firebase Firestore.
# This is the Firebase Project ID only — no API key needed on the backend.
FIREBASE_PROJECT_ID=crm-project-management-f21f3
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
